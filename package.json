{
  "name": "notifyzen-every-where",
  "version": "1.1.9",
  "description": "The Universal Notification Engine: Zero-config FCM support for React, Next.js, Vue, and React Native.",
  "author": "umeshbakotiyadev",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "notifications",
    "react",
    "nextjs",
    "vue",
    "react-native",
    "firebase",
    "fcm",
    "notifyzen",
    "universal",
    "fingerprint"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/umeshbakotiyadev/NotifyZen-Every-Where.git"
  },
  "homepage": "https://github.com/umeshbakotiyadev/NotifyZen-Every-Where/tree/main/docs",
  "bugs": {
    "url": "https://github.com/umeshbakotiyadev/NotifyZen-Every-Where/issues"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.60.0",
    "firebase": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.8",
    "firebase": "^12.12.1",
    "react": "^19.2.5",
    "react-native": "^0.85.3",
    "react-native-device-info": "^15.0.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}